rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 도안 이미지: 본인만 읽기/쓰기
    match /users/{userId}/patterns/{patternId}/{filename} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 게시글 이미지: 누구나 읽기, 메타데이터에 ownerUid를 본인으로 지정하여 쓰기 가능. 삭제는 본인만.
    match /posts/{postId}/images/{filename} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.metadata.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.metadata.ownerUid == request.auth.uid;
    }

    // 프로필 사진: 누구나 읽기, 본인만 쓰기
    match /users/{userId}/profile/{filename} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 프로젝트 도안 PDF: 본인만 업로드/조회/삭제 가능
    match /users/{userId}/projects/{projectId}/pattern.pdf {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // 프로젝트 진행 사진: 본인만 읽고 쓰기 가능
    match /users/{userId}/projects/{projectId}/photos/{filename} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && (request.method == 'GET' || request.resource.contentType.matches('image/.*'));
    }

    // 실 재고 관리 (Yarn Stash) 사진: 본인만 읽고 쓰기 가능
    match /users/{userId}/yarns/{filename} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && (request.method == 'GET' || request.resource.contentType.matches('image/.*'));
    }
  }
}
