rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자 프로필
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;

      // 내 도안
      match /patterns/{patternId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }

      // 좋아요
      match /likes/{postId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // 스크랩
      match /scraps/{postId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // 단수 카운터 Firestore 백업
      match /rowCounters/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // 배색 팔레트
      match /palettes/{paletteId} {
        allow read: if resource.data.isPublic == true
          || (request.auth != null && request.auth.uid == userId);
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // 뜨개 프로젝트
      match /projects/{projectId} {
        allow read: if resource.data.isPublic == true 
                     || (request.auth != null && request.auth.uid == userId);
        allow write: if request.auth != null && request.auth.uid == userId;

        match /parts/{partId} {
          allow read, write: if request.auth != null
            && request.auth.uid == userId;
        }

        match /photos/{photoId} {
          allow read, write: if request.auth != null
            && request.auth.uid == userId;
        }
      }

      // 실 재고 관리 (Yarn Stash)
      match /yarns/{yarnId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 게시글
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'scrapCount', 'commentCount'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;

      // 댓글
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
        allow update: if request.auth != null && request.auth.uid == resource.data.uid;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uid;

        // 답글
        match /replies/{replyId} {
          allow read: if true;
          allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
          allow update: if request.auth != null && request.auth.uid == resource.data.uid;
          allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
        }
      }
    }

    // 매거진 좋아요
    match /users/{userId}/magazineLikes/{articleId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 매거진 스크랩
    match /users/{userId}/magazineScraps/{articleId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 매거진 아티클 (카운트 + 댓글)
    match /magazine/{articleId} {
      allow read: if true;
      // 첫 좋아요·스크랩·댓글 시 문서가 없으면 create, 있으면 update
      allow create: if request.auth != null &&
        request.resource.data.keys().hasOnly(['likeCount', 'scrapCount', 'commentCount']);
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likeCount', 'scrapCount', 'commentCount']);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
        allow update: if request.auth != null && request.auth.uid == resource.data.uid;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uid;

        match /replies/{replyId} {
          allow read: if true;
          allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
          allow update: if request.auth != null && request.auth.uid == resource.data.uid;
          allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
        }
      }
    }

    // 닉네임 예약
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // 팔로우
    match /follows/{docId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.followerId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.followerId == request.auth.uid;
    }
  }
}
